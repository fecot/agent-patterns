NODE_ENV=development

# DB / Queue / Storage は docker compose のサービス名で解決する。
DATABASE_URL=postgres://postgres:postgres@postgres:5432/agent_training
REDIS_URL=redis://redis:6379

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=generated-files

# LLM Provider: openai | anthropic | mock
# デフォルトは mock。API キーなしで学習・CI できる。
LLM_PROVIDER=mock

# OpenAI を使う場合のみ設定。モデル名は実行時点で利用可能なものに差し替えること。
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic を使う場合のみ設定 (Provider 本実装は後続フェーズ)。
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8080
